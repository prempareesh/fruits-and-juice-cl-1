{
  "expo": {
    "name": "Juicy App",
    "slug": "juice-shop-customer",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "sdkVersion": "52.0.0",
    "newArchEnabled": false,
    "scheme": "juice-shop",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.preetham.juiceshop"
    },
    "android": {
      "package": "com.preetham.juiceshop",
      "versionCode": 4,
      "permissions": [
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "juice-shop"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "edgeToEdgeEnabled": true
    },
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#ffffff"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-build-properties",
        {
          "android": {
            "multiDexEnabled": true,
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "kotlinVersion": "1.9.25",
            "gradleProperties": {
              "kotlin.suppressKotlinVersionCompatibilityCheck": "true",
              "compose.kotlin.suppressKotlinVersionCompatibilityCheck": "true"
            }
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4c9466ed-6594-4aaf-ab09-d50fcfb1c18b"
      }
    },
    "owner": "love1"
  }
}
