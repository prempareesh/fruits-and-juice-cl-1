import { useEffect, useState } from 'react';
import { supabase } from '../../lib/supabase';

export interface StoreSettings {
  store_open: boolean;
  delivery_radius: number;
  min_order_amount: number;
  base_delivery_fee: number;
  store_address: string;
  store_lat: number;
  store_lng: number;
  support_phone: string;
  estimated_delivery_time: string;
}

export function useSettings() {
  const [settings, setSettings] = useState<StoreSettings | null>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetchSettings();

    // Create a unique channel name to avoid collisions during Fast Refresh
    const channelId = `settings_${Math.random().toString(36).substring(7)}`;
    const channel = supabase.channel(channelId);

    channel
      .on(
        'postgres_changes',
        { 
          event: 'UPDATE', 
          schema: 'public', 
          table: 'settings', 
          filter: 'id=eq.store_settings' 
        },
        (payload) => {
          console.log('[SETTINGS_REALTIME] Update detected:', payload.new);
          if (payload.new) {
            setSettings(payload.new as StoreSettings);
          }
        }
      )
      .subscribe((status) => {
        console.log(`[SETTINGS_REALTIME] Status for ${channelId}:`, status);
      });

    return () => {
      console.log(`[SETTINGS_REALTIME] Cleaning up ${channelId}`);
      supabase.removeChannel(channel);
    };
  }, []);

  const fetchSettings = async () => {
    try {
      const { data, error } = await supabase
        .from('settings')
        .select('*')
        .eq('id', 'store_settings')
        .single();

      if (!error && data) {
        setSettings(data as StoreSettings);
      }
    } catch (err) {
      console.error('Error fetching settings:', err);
    } finally {
      setLoading(false);
    }
  };

  return { settings, loading, isClosed: settings?.store_open === false };
}
